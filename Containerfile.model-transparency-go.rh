FROM registry.redhat.io/ubi9/go-toolset:9.8-1784190466@sha256:f99dd81b20e5971ef9f63a51ac27cf0aa591ff9921d021490548b67fd9b17144 AS build-env

ARG BUILD_TAGS=""

ENV APP_ROOT=/opt/app-root \
    GOPATH=/opt/app-root \
    GOFLAGS="-buildvcs=false"

USER root

RUN mkdir -p /opt/app-root/src && git config --global --add safe.directory /opt/app-root/src

WORKDIR /opt/app-root/src

COPY . .

RUN go mod vendor

RUN set -euo pipefail; \
    GIT_VERSION="$(git describe --tags --always --dirty 2>/dev/null || echo v0.0.0)"; \
    GIT_HASH="$(git rev-parse HEAD 2>/dev/null || echo unknown)"; \
    GIT_TREESTATE="clean"; \
    BUILD_DATE="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"; \
    LDFLAGS="-X sigs.k8s.io/release-utils/version.gitVersion=${GIT_VERSION} \
             -X sigs.k8s.io/release-utils/version.gitCommit=${GIT_HASH} \
             -X sigs.k8s.io/release-utils/version.gitTreeState=${GIT_TREESTATE} \
             -X sigs.k8s.io/release-utils/version.buildDate=${BUILD_DATE} \
             -w -s"; \
    git update-index --assume-unchanged Containerfile.model-transparency-go.rh; \
    git update-index --assume-unchanged Containerfile.cli-stack.rh; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS}" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli ./cmd/model-signing; \
    cp model_transparency_cli model_transparency_cli_linux; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS},pkcs11" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli_pkcs11_linux ./cmd/model-signing; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS},otel" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli_otel_linux ./cmd/model-signing; \
    git update-index --no-assume-unchanged Containerfile.model-transparency-go.rh; \
    git update-index --no-assume-unchanged Containerfile.cli-stack.rh

FROM registry.redhat.io/ubi9/ubi-minimal@sha256:062c52ff973065752b0965787649db2bcf551a6c727a00e95a3eb42cebadbdab

COPY --from=build-env /opt/app-root/src/model_transparency_cli /usr/local/bin/model_transparency_cli
COPY --from=build-env /opt/app-root/src/model_transparency_cli_linux /usr/local/bin/model_transparency_cli_linux
COPY --from=build-env /opt/app-root/src/model_transparency_cli_pkcs11_linux /usr/local/bin/model_transparency_cli_pkcs11_linux
COPY --from=build-env /opt/app-root/src/model_transparency_cli_otel_linux /usr/local/bin/model_transparency_cli_otel_linux

COPY LICENSE /licenses/license.txt

WORKDIR /opt/app-root/src/home

USER 65532:65532
 
ENTRYPOINT ["model_transparency_cli"]
CMD ["--help"]

LABEL description="Supply chain security for ML"
LABEL io.k8s.description="Supply chain security for ML"
LABEL io.k8s.display-name="Go based Model Transparency Library"
LABEL io.openshift.tags="model transparency security ml"
LABEL summary="Provides a go library for model transparency."
LABEL com.redhat.component="model-transparency-go"
LABEL name="rhtas/model-transparency-cli-rhel9"
