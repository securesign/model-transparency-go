FROM registry.redhat.io/ubi9/go-toolset:9.7-1774618347@sha256:0f4f6f7868962aa75dddfe4230b664bdf77071e92c43c70c824c58450e37693f AS build-env

ARG BUILD_TAGS=""

ENV APP_ROOT=/opt/app-root \
    GOPATH=/opt/app-root \
    GOFLAGS="-buildvcs=false"

USER root

RUN mkdir -p /opt/app-root/src && git config --global --add safe.directory /opt/app-root/src

WORKDIR /opt/app-root/src

COPY . .

RUN go mod vendor

RUN set -euo pipefail; \
    NATIVE_ARCH="$(go env GOARCH)"; \
    GIT_VERSION="$(git describe --tags --always --dirty 2>/dev/null || echo v0.0.0)"; \
    GIT_HASH="$(git rev-parse HEAD 2>/dev/null || echo unknown)"; \
    GIT_TREESTATE="clean"; \
    BUILD_DATE="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"; \
    LDFLAGS="-X sigs.k8s.io/release-utils/version.gitVersion=${GIT_VERSION} \
             -X sigs.k8s.io/release-utils/version.gitCommit=${GIT_HASH} \
             -X sigs.k8s.io/release-utils/version.gitTreeState=${GIT_TREESTATE} \
             -X sigs.k8s.io/release-utils/version.buildDate=${BUILD_DATE} \
             -w -s"; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS}" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli ./cmd/model-signing; \
    cp model_transparency_cli "model_transparency_cli_linux_${NATIVE_ARCH}"; \
    tar czf "model_transparency_cli_linux_${NATIVE_ARCH}.tar.gz" "model_transparency_cli_linux_${NATIVE_ARCH}"; \
    CGO_ENABLED=0 GOOS=darwin GOARCH=amd64 go build -tags="${BUILD_TAGS}" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli_darwin_amd64 ./cmd/model-signing; \
    tar czf model_transparency_cli_darwin_amd64.tar.gz model_transparency_cli_darwin_amd64; \
    CGO_ENABLED=0 GOOS=darwin GOARCH=arm64 go build -tags="${BUILD_TAGS}" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli_darwin_arm64 ./cmd/model-signing; \
    tar czf model_transparency_cli_darwin_arm64.tar.gz model_transparency_cli_darwin_arm64; \
    CGO_ENABLED=0 GOOS=windows GOARCH=amd64 go build -tags="${BUILD_TAGS}" -trimpath -ldflags "${LDFLAGS}" \
        -o model_transparency_cli_windows_amd64.exe ./cmd/model-signing; \
    tar czf model_transparency_cli_windows_amd64.exe.gz model_transparency_cli_windows_amd64.exe; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS},pkcs11" -trimpath -ldflags "${LDFLAGS}" \
        -o "model_transparency_cli_pkcs11_linux_${NATIVE_ARCH}" ./cmd/model-signing; \
    tar czf "model_transparency_cli_pkcs11_linux_${NATIVE_ARCH}.tar.gz" "model_transparency_cli_pkcs11_linux_${NATIVE_ARCH}"; \
    CGO_ENABLED=1 go build -tags="${BUILD_TAGS},otel" -trimpath -ldflags "${LDFLAGS}" \
        -o "model_transparency_cli_otel_linux_${NATIVE_ARCH}" ./cmd/model-signing; \
    tar czf "model_transparency_cli_otel_linux_${NATIVE_ARCH}.tar.gz" "model_transparency_cli_otel_linux_${NATIVE_ARCH}"

FROM registry.redhat.io/ubi9/ubi-minimal@sha256:83006d535923fcf1345067873524a3980316f51794f01d8655be55d6e9387183 AS deploy

COPY --from=build-env /opt/app-root/src/model_transparency_cli /usr/local/bin/model_transparency_cli
COPY --from=build-env /opt/app-root/src/model_transparency_cli_linux_*.tar.gz /usr/local/bin/
COPY --from=build-env /opt/app-root/src/model_transparency_cli_darwin_*.tar.gz /usr/local/bin/
COPY --from=build-env /opt/app-root/src/model_transparency_cli_windows_*.exe.gz /usr/local/bin/
COPY --from=build-env /opt/app-root/src/model_transparency_cli_pkcs11_linux_*.tar.gz /usr/local/bin/
COPY --from=build-env /opt/app-root/src/model_transparency_cli_otel_linux_*.tar.gz /usr/local/bin/

COPY LICENSE /licenses/license.txt

WORKDIR /opt/app-root/src/home

USER 65532:65532
 
ENTRYPOINT ["model_transparency_cli"]
CMD ["--help"]

LABEL description="Supply chain security for ML"
LABEL io.k8s.description="Supply chain security for ML"
LABEL io.k8s.display-name="Go based Model Transparency Library"
LABEL io.openshift.tags="model transparency security ml"
LABEL summary="Provides a go library for model transparency."
LABEL com.redhat.component="model-transparency-go"
LABEL name="rhtas/model-transparency-cli-rhel9"
