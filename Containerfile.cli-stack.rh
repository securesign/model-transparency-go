FROM registry.redhat.io/ubi9/go-toolset:9.8-1782910875@sha256:5488ab924e20c14a7a765b8502e0798fad0e0953f67d552bf43d795583020819 AS build-cross-platform
ENV APP_ROOT=/opt/app-root \
    GOPATH=/opt/app-root

USER root
WORKDIR $APP_ROOT/src
ADD go.mod go.sum ./
ADD ./ ./

RUN git config --global --add safe.directory /opt/app-root/src && \
    git update-index --assume-unchanged Containerfile.model-transparency-go.rh && \
    git update-index --assume-unchanged Containerfile.cli-stack.rh && \
    go mod download && \
    make cross-platform-binaries

FROM --platform=linux/amd64   quay.io/securesign/model-transparency-go@sha256:a08467cac1edba06e91929b5beb902f71bf85108d2d382c25c662a27cb568290 AS build-amd64
FROM --platform=linux/arm64   quay.io/securesign/model-transparency-go@sha256:e2157e8ddc8b1d54827fd4e1b9a412098a1a7c70f2bd178cdab2d7379fa2af48 AS build-arm64
FROM --platform=linux/ppc64le quay.io/securesign/model-transparency-go@sha256:f255ae297c4a0b80ca464abd4174ed7c38a819d78a56e81bc3e9740b7313cdab AS build-ppc64le
FROM --platform=linux/s390x   quay.io/securesign/model-transparency-go@sha256:df40b5f102152d40f8da3630416290d515d1b9ed93475ad808eb0481d1bc128c AS build-s390x

FROM registry.redhat.io/ubi9/go-toolset:9.8-1782910875@sha256:5488ab924e20c14a7a765b8502e0798fad0e0953f67d552bf43d795583020819 AS packager
USER root
RUN mkdir -p /binaries

# Standard CLI: Native Linux binaries from each arch variant
COPY --from=build-amd64 /usr/local/bin/model_transparency_cli_linux /tmp/model_transparency_cli_linux
RUN tar -czf /binaries/model_transparency_cli_linux_amd64.tar.gz -C /tmp model_transparency_cli_linux && \
    rm /tmp/model_transparency_cli_linux

COPY --from=build-arm64 /usr/local/bin/model_transparency_cli_linux /tmp/model_transparency_cli_linux
RUN tar -czf /binaries/model_transparency_cli_linux_arm64.tar.gz -C /tmp model_transparency_cli_linux && \
    rm /tmp/model_transparency_cli_linux

COPY --from=build-ppc64le /usr/local/bin/model_transparency_cli_linux /tmp/model_transparency_cli_linux
RUN tar -czf /binaries/model_transparency_cli_linux_ppc64le.tar.gz -C /tmp model_transparency_cli_linux && \
    rm /tmp/model_transparency_cli_linux

COPY --from=build-s390x /usr/local/bin/model_transparency_cli_linux /tmp/model_transparency_cli_linux
RUN tar -czf /binaries/model_transparency_cli_linux_s390x.tar.gz -C /tmp model_transparency_cli_linux && \
    rm /tmp/model_transparency_cli_linux

# PKCS11 CLI: Native Linux binaries from each arch variant
COPY --from=build-amd64 /usr/local/bin/model_transparency_cli_pkcs11_linux /tmp/model_transparency_cli_pkcs11_linux
RUN tar -czf /binaries/model_transparency_cli_pkcs11_linux_amd64.tar.gz -C /tmp model_transparency_cli_pkcs11_linux && \
    rm /tmp/model_transparency_cli_pkcs11_linux

COPY --from=build-arm64 /usr/local/bin/model_transparency_cli_pkcs11_linux /tmp/model_transparency_cli_pkcs11_linux
RUN tar -czf /binaries/model_transparency_cli_pkcs11_linux_arm64.tar.gz -C /tmp model_transparency_cli_pkcs11_linux && \
    rm /tmp/model_transparency_cli_pkcs11_linux

COPY --from=build-ppc64le /usr/local/bin/model_transparency_cli_pkcs11_linux /tmp/model_transparency_cli_pkcs11_linux
RUN tar -czf /binaries/model_transparency_cli_pkcs11_linux_ppc64le.tar.gz -C /tmp model_transparency_cli_pkcs11_linux && \
    rm /tmp/model_transparency_cli_pkcs11_linux

COPY --from=build-s390x /usr/local/bin/model_transparency_cli_pkcs11_linux /tmp/model_transparency_cli_pkcs11_linux
RUN tar -czf /binaries/model_transparency_cli_pkcs11_linux_s390x.tar.gz -C /tmp model_transparency_cli_pkcs11_linux && \
    rm /tmp/model_transparency_cli_pkcs11_linux

# OTel CLI: Native Linux binaries from each arch variant
COPY --from=build-amd64 /usr/local/bin/model_transparency_cli_otel_linux /tmp/model_transparency_cli_otel_linux
RUN tar -czf /binaries/model_transparency_cli_otel_linux_amd64.tar.gz -C /tmp model_transparency_cli_otel_linux && \
    rm /tmp/model_transparency_cli_otel_linux

COPY --from=build-arm64 /usr/local/bin/model_transparency_cli_otel_linux /tmp/model_transparency_cli_otel_linux
RUN tar -czf /binaries/model_transparency_cli_otel_linux_arm64.tar.gz -C /tmp model_transparency_cli_otel_linux && \
    rm /tmp/model_transparency_cli_otel_linux

COPY --from=build-ppc64le /usr/local/bin/model_transparency_cli_otel_linux /tmp/model_transparency_cli_otel_linux
RUN tar -czf /binaries/model_transparency_cli_otel_linux_ppc64le.tar.gz -C /tmp model_transparency_cli_otel_linux && \
    rm /tmp/model_transparency_cli_otel_linux

COPY --from=build-s390x /usr/local/bin/model_transparency_cli_otel_linux /tmp/model_transparency_cli_otel_linux
RUN tar -czf /binaries/model_transparency_cli_otel_linux_s390x.tar.gz -C /tmp model_transparency_cli_otel_linux && \
    rm /tmp/model_transparency_cli_otel_linux

# Cross-compiled binaries
COPY --from=build-cross-platform /opt/app-root/src/build/model_transparency_cli_darwin_amd64 /tmp/model_transparency_cli_darwin_amd64
RUN tar -czf /binaries/model_transparency_cli_darwin_amd64.tar.gz -C /tmp model_transparency_cli_darwin_amd64 && \
    rm /tmp/model_transparency_cli_darwin_amd64

COPY --from=build-cross-platform /opt/app-root/src/build/model_transparency_cli_darwin_arm64 /tmp/model_transparency_cli_darwin_arm64
RUN tar -czf /binaries/model_transparency_cli_darwin_arm64.tar.gz -C /tmp model_transparency_cli_darwin_arm64 && \
    rm /tmp/model_transparency_cli_darwin_arm64

COPY --from=build-cross-platform /opt/app-root/src/build/model_transparency_cli_windows_amd64.exe /tmp/model_transparency_cli_windows_amd64.exe
RUN tar -czf /binaries/model_transparency_cli_windows_amd64.tar.gz -C /tmp model_transparency_cli_windows_amd64.exe && \
    rm /tmp/model_transparency_cli_windows_amd64.exe

RUN chmod -R a+rX /binaries

# Final minimal image with all binaries
FROM registry.redhat.io/ubi9/ubi-micro:9.8-1782840931@sha256:35de56a9413112f1474e392ebc35e0cf6f0fb484c8e8877bbae59b513694b41f

LABEL description="Flat image containing model-transparency CLI binaries for all platforms and architectures"
LABEL io.k8s.description="Flat image containing model-transparency CLI binaries for all platforms and architectures"
LABEL io.opencontainers.image.description="Flat image containing model-transparency CLI binaries for all platforms and architectures"
LABEL io.k8s.display-name="Model Transparency CLI stack image for Red Hat Trusted Artifact Signer"
LABEL io.openshift.tags="model-transparency trusted-artifact-signer cli-stack"
LABEL summary="Provides model-transparency CLI binaries as tar.gz archives for CDN distribution."
LABEL com.redhat.component="model-transparency-cli-stack"
LABEL name="rhtas/model-transparency-cli-stack"

COPY --from=packager /binaries/ /binaries/
COPY --from=build-amd64 /licenses/ /licenses/

USER 65532:65532
